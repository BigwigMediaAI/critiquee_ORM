        ],
        "locations": [
          "https://images.unsplash.com/photo-1758193783649-13371d7fb8dd?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1Mjh8MHwxfHNlYXJjaHw0fHxtb2Rlcm4lMjBob3RlbCUyMGxvYmJ5JTIwbHV4dXJ5JTIwaW50ZXJpb3J8ZW58MHx8fHwxNzcxNTc5NDk3fDA&ixlib=rb-4.1.0&q=85",
          "https://images.pexels.com/photos/34077115/pexels-photo-34077115.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
        ],
        "placeholders": {
          "logo": "https://via.placeholder.com/150",
          "cover": "https://via.placeholder.com/800x400"
        }
      }
    }
  },
  "implementation_guide": {
    "phases": [
      "1. Setup Base Layout (Sidebar + Navbar + Content Area)",
      "2. Implement Dashboard Grid (Overview + Charts)",
      "3. Build Review Management Module (List + Filters + Reply)",
      "4. Build Social Feed Module (Card Layout + Reply)",
      "5. Implement Settings & User Management"
    ],
    "universal_guidelines": [
      "Use 'Manrope' for all Headings (h1-h3) and 'Public Sans' for body text.",
      "NEVER use generic 'Inter' for Headings.",
      "Primary Action Buttons must be solid Primary color.",
      "Secondary actions should be Ghost or Outline.",
      "Use Shadcn 'Card' for all dashboard widgets.",
      "Add 'data-testid' to all interactive elements.",
      "Ensure Dark Mode support for every component using the 'dark:' prefix.",
      "Use 'sonner' for all toast notifications.",
      "Use 'lucide-react' for interface icons.",
      "Use 'react-icons' specifically for brand logos (Google, Facebook, etc.).",
      "Do not use gradients for backgrounds, keep it flat and clean.",
      "Use 'recharts' for all analytics charts."
    ],
    "specific_instructions": {
      "dashboard": "Use the 'Bento Mode B' (High Density) grid. Summary cards at top, main chart in middle, recent activity list on right.",
      "review_card": "Card should show star rating clearly. Use Yellow-500 for stars. Platform icon (Google/FB) in top right.",
      "ai_reply": "AI suggestions should appear in a subtle highlighted box (bg-violet-50 dark:bg-violet-900/20) with a 'Sparkles' icon.",
      "sidebar": "Fixed left sidebar. Active state must have a distinct background color (accent) and primary text color.",
      "notifications": "Use a red dot (bg-red-500) for unread notifications. Animate the dot with a pulse effect."
    }
  }
}